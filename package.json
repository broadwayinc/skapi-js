{
  "name": "skapi-js",
  "version": "1.5.0-beta.3",
  "description": "Serverless Backend API for AI Agents.",
  "main": "dist/skapi.cjs",
  "browser": "dist/skapi.mjs",
  "module": "dist/skapi.mjs",
  "unpkg": "dist/skapi.js",
  "jsdelivr": "dist/skapi.js",
  "types": "dist/skapi.d.ts",
  "exports": {
    ".": {
      "types": "./dist/skapi.d.ts",
      "browser": "./dist/skapi.mjs",
      "import": "./dist/skapi.mjs",
      "require": "./dist/skapi.cjs",
      "default": "./dist/skapi.cjs"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "npx tsup && node ./src/main/typedoc.js",
    "test:node-imports": "node ./tests/node-import-compatibility.cjs",
    "dev": "npx bns 3333"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/broadwayinc/skapi-js.git"
  },
  "author": "Baksa Gimm",
  "copyright.owner": "broadway Inc.",
  "license": "Apache-2.0",
  "bugs": {
    "url": "https://github.com/broadwayinc/skapi-js/issues"
  },
  "homepage": "https://www.skapi.com",
  "dependencies": {
    "amazon-cognito-identity-js": "^6.3.16",
    "cocochex": "^1.0.4",
    "qpass": "^1.1.0"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "basic-node-server": "^1.0.16",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3"
  },
  "keywords": [
    "backend",
    "skapi",
    "api",
    "serverless",
    "database"
  ]
}
